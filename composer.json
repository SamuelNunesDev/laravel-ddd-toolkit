{
    "name": "samuel-nunes/laravel-ddd-toolkit",
    "description": "A pragmatic tactical DDD toolkit for modular Laravel applications.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Samuel Nunes"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "nikic/php-parser": "^5.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.5|^11.0",
        "vimeo/psalm": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "SamuelNunes\\LaravelDddToolkit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SamuelNunes\\LaravelDddToolkit\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SamuelNunes\\LaravelDddToolkit\\LaravelDddToolkitServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text",
        "analyse": "psalm --no-cache --show-info=false",
        "check": [
            "@test",
            "@analyse"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
